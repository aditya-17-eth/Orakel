# Orakel — environment template.
# Copy to .env (which is gitignored) and fill in the secrets:  cp .env.example .env
# NEVER put real secret seeds or API tokens in THIS file — it is committed.

# --- Shared runtime config (non-secret; safe to commit) --------------------
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CONTRACT_ID=CCSSW2PLSWIF67GPHUUK64LBSPAPVL3PZH2OEZWCCQIGUUN475ZH55UY
USDC_SAC=CDI5NQEKCZ67GAL57E3CUFQ3P6WCB3O4Q4DQIJDLP3UCLEJLFCYGXKKX
REFLECTOR_CONTRACT=CCYOZJCOPG34LLQQ7N24YXBM7LL62R7ONMZ3G6WZAAYPB5OYKOMJRN63

# --- Secrets (REQUIRED by the bots; keep only in your local .env) -----------
# Keeper signing key (S...). Get it with:  stellar keys secret keeper
KEEPER_SECRET=S...replace_me
# Pinata JWT for pinning evidence bundles (Pinata dashboard -> API Keys).
PINATA_JWT=replace_me

# --- Telegram alerts (optional; without these, messages log to console) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Keeper behavior --------------------------------------------------------
# Set to true ONLY for the adversarial test — inverts every proposed outcome.
LIE_MODE=false

